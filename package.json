{
  "name": "dnd-control-console",
  "version": "1.0.0",
  "description": "A modular D&D control console with Electron, Vite, and TypeScript.",
  "author": "Charles",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "npm run kill-ports && npm run build:electron && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "wait-on http://localhost:5173 && electron ./dist/electron/main.js",
    "kill-ports": "node -e \"const{execSync}=require('child_process');[5173,3001,3002].forEach(p=>{try{const r=execSync('netstat -ano | findstr :'+p+' | findstr LISTENING',{encoding:'utf8'});r.split('\\n').forEach(l=>{const pid=l.trim().split(/\\s+/).pop();if(pid&&pid!=='0')try{process.kill(Number(pid))}catch(e){}});}catch(e){}});\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build --config vite.config.ts",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder --win --x64",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "build": {
    "appId": "com.charles.dnd-control-console",
    "productName": "DnD Control Console",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "remote/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "seeds",
        "to": "seeds",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon_fixed.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "express": "^4.19.0",
    "uuid": "^13.0.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "keywords": [],
  "license": "ISC"
}
