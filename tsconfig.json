{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": true
  },
  "include": [
    "*.tsx",
    "*.ts",
    "src/**/*.tsx",
    "src/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": [
    "electron/**/*",
    "node_modules/**/*",
    "dist/**/*"
  ]
}