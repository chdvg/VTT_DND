{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "electron/**/*.ts",
    "shared/types/**/*.ts"
  ],
  "exclude": [
    "src/**/*",
    "remote/**/*",
    "dist/**/*",
    "node_modules/**/*"
  ]
}